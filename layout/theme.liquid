<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="{{ settings.color_background }}">
    <link rel="canonical" href="{{ canonical_url }}">

    {% if settings.favicon != blank %}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {% endif %}

    {% unless settings.type_header_font.system? and settings.type_body_font.system? %}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {% endunless %}
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

    <title>
      {{ page_title }}
      {% if current_tags %}
        &ndash; tagged {{ current_tags | join: ', ' }}
      {% endif %}
      {% if current_page != 1 %}
        &ndash; Page {{ current_page }}
      {% endif %}
      {% unless page_title contains shop.name %}
        &ndash; {{ shop.name }}
      {% endunless %}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {% style %}
      :root {
        --page-width: 120rem;
        --space-2: 0.8rem;
        --space-4: 1.6rem;
        --space-6: 2.4rem;
        --space-8: 3.2rem;
        --space-12: 4.8rem;
      }
      * { box-sizing: border-box; }
      html { font-size: 62.5%; }
      body {
        margin: 0;
        font-size: 1.8rem;
        line-height: 1.5;
        color: #111;
        background: #fff;
        font-family: Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      }
      .page-width {
        width: min(100% - 3.2rem, var(--page-width));
        margin-inline: auto;
      }
      .site-header,
      .site-footer { padding: var(--space-6) 0; }
      .site-header__logo { color: inherit; text-decoration: none; font-size: 2.2rem; font-weight: 700; }
      .section { padding: var(--space-12) 0; }
      .content-visibility-auto {
        content-visibility: auto;
        contain-intrinsic-size: 1px 1000px;
      }
    {% endstyle %}

    {{ content_for_header }}

    <link rel="preload" href="{{ 'base.css' | asset_url }}" as="style">
    <link rel="stylesheet" href="{{ 'base.css' | asset_url }}" media="print" onload="this.media='all'">
    <noscript>{{ 'base.css' | asset_url | stylesheet_tag }}</noscript>

    {% if template.name == 'product' %}
      <link rel="preload" href="{{ 'component-sticky-atc.css' | asset_url }}" as="style">
      <link rel="stylesheet" href="{{ 'component-sticky-atc.css' | asset_url }}" media="print" onload="this.media='all'">
      <noscript>{{ 'component-sticky-atc.css' | asset_url | stylesheet_tag }}</noscript>
    {% endif %}

    <script>
      document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
      window.theme = window.theme || {};
      window.theme.moneyFormat = {{ shop.money_format | json }};
    </script>
    <script src="{{ 'theme.js' | asset_url }}" defer="defer"></script>
  </head>
  <body>
    <a class="skip-to-content-link button visually-hidden" href="#MainContent">{{ 'accessibility.skip_to_text' | t }}</a>

    <header class="site-header page-width">
      <a href="{{ routes.root_url }}" class="site-header__logo">{{ shop.name }}</a>
    </header>

    <main id="MainContent" class="content-for-layout content-visibility-auto" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    <footer class="site-footer page-width">
      <small>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ powered_by_link }}</small>
    </footer>
  </body>
</html>

<section class="hc-hero hc-hero--{{ section.id }}" data-section-id="{{ section.id }}">
  <div class="hc-hero__media">
    {% if section.settings.background_image != blank %}
      {{
        section.settings.background_image
        | image_url: width: 2400
        | image_tag:
          class: 'hc-hero__image',
          widths: '375, 550, 750, 1100, 1500, 2000, 2400',
          sizes: '100vw',
          loading: 'eager',
          decoding: 'async',
          fetchpriority: 'high',
          alt: section.settings.background_image.alt | default: section.settings.headline
      }}
    {% else %}
      <div class="hc-hero__placeholder" aria-hidden="true"></div>
    {% endif %}
    <div class="hc-hero__overlay"></div>
  </div>

  <div class="hc-hero__content page-width hc-hero__fade-in">
    {% if section.settings.headline != blank %}
      <h1 class="hc-hero__headline">{{ section.settings.headline }}</h1>
    {% endif %}

    {% if section.settings.subheadline != blank %}
      <p class="hc-hero__subheadline">{{ section.settings.subheadline }}</p>
    {% endif %}

    <div class="hc-hero__actions">
      {% if section.settings.cta_label != blank and section.settings.cta_link != blank %}
        <a class="hc-hero__button hc-hero__button--primary" href="{{ section.settings.cta_link }}">
          {{ section.settings.cta_label }}
        </a>
      {% endif %}

      {% if section.settings.secondary_cta_label != blank and section.settings.secondary_cta_link != blank %}
        <a class="hc-hero__button hc-hero__button--secondary" href="{{ section.settings.secondary_cta_link }}">
          {{ section.settings.secondary_cta_label }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

<style>
  .hc-hero--{{ section.id }} {
    position: relative;
    isolation: isolate;
    min-height: {{ section.settings.hero_height_mobile }}vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    color: {{ section.settings.text_color }};
  }

  .hc-hero--{{ section.id }} .hc-hero__media,
  .hc-hero--{{ section.id }} .hc-hero__overlay {
    position: absolute;
    inset: 0;
  }

  .hc-hero--{{ section.id }} .hc-hero__image,
  .hc-hero--{{ section.id }} .hc-hero__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hc-hero--{{ section.id }} .hc-hero__placeholder {
    background: linear-gradient(140deg, #1f2937, #4b5563);
  }

  .hc-hero--{{ section.id }} .hc-hero__overlay {
    background: rgba(0, 0, 0, {{ section.settings.overlay_opacity | times: 0.01 }});
    z-index: 1;
  }

  .hc-hero--{{ section.id }} .hc-hero__content {
    position: relative;
    z-index: 2;
    width: 100%;
    text-align: {{ section.settings.text_alignment_mobile }};
    padding-top: 3rem;
    padding-bottom: 3rem;
  }

  .hc-hero--{{ section.id }} .hc-hero__headline {
    font-size: clamp(2rem, 7vw, 4.5rem);
    line-height: 1.05;
    margin: 0;
    max-width: 14ch;
    letter-spacing: -0.02em;
  }

  .hc-hero--{{ section.id }} .hc-hero__subheadline {
    margin: 1rem 0 0;
    font-size: clamp(1rem, 2.5vw, 1.4rem);
    line-height: 1.5;
    max-width: 60ch;
  }

  .hc-hero--{{ section.id }} .hc-hero__actions {
    margin-top: 1.75rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: {% if section.settings.text_alignment_mobile == 'center' %}center{% elsif section.settings.text_alignment_mobile == 'right' %}flex-end{% else %}flex-start{% endif %};
  }

  .hc-hero--{{ section.id }} .hc-hero__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    padding: 0.75rem 1.5rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 600;
    transition: transform 0.2s ease, opacity 0.2s ease, background-color 0.2s ease, color 0.2s ease;
  }

  .hc-hero--{{ section.id }} .hc-hero__button:hover,
  .hc-hero--{{ section.id }} .hc-hero__button:focus-visible {
    transform: translateY(-1px);
    opacity: 0.92;
  }

  .hc-hero--{{ section.id }} .hc-hero__button--primary {
    background: {{ section.settings.primary_button_bg }};
    color: {{ section.settings.primary_button_text }};
  }

  .hc-hero--{{ section.id }} .hc-hero__button--secondary {
    border: 1px solid {{ section.settings.secondary_button_border }};
    color: {{ section.settings.secondary_button_text }};
    background: {{ section.settings.secondary_button_bg }};
  }

  .hc-hero--{{ section.id }} .hc-hero__fade-in {
    opacity: 0;
    transform: translateY(16px);
    animation: hcHeroFadeIn-{{ section.id }} 0.8s ease forwards;
    animation-delay: 0.2s;
  }

  @keyframes hcHeroFadeIn-{{ section.id }} {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media screen and (min-width: 750px) {
    .hc-hero--{{ section.id }} {
      min-height: {{ section.settings.hero_height_desktop }}vh;
    }

    .hc-hero--{{ section.id }} .hc-hero__content {
      text-align: {{ section.settings.text_alignment_desktop }};
    }

    .hc-hero--{{ section.id }} .hc-hero__actions {
      justify-content: {% if section.settings.text_alignment_desktop == 'center' %}center{% elsif section.settings.text_alignment_desktop == 'right' %}flex-end{% else %}flex-start{% endif %};
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hc-hero--{{ section.id }} .hc-hero__fade-in {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>

{% schema %}
{
  "name": "High-converting hero",
  "settings": [
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Transform your routine in 30 days"
    },
    {
      "type": "textarea",
      "id": "subheadline",
      "label": "Subheadline",
      "default": "Join thousands of customers who improved their daily results with our best-selling solution."
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Image overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 35
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Primary CTA label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Primary CTA link"
    },
    {
      "type": "text",
      "id": "secondary_cta_label",
      "label": "Secondary CTA label",
      "default": "Learn more"
    },
    {
      "type": "url",
      "id": "secondary_cta_link",
      "label": "Secondary CTA link"
    },
    {
      "type": "select",
      "id": "text_alignment_mobile",
      "label": "Text alignment (mobile)",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "text_alignment_desktop",
      "label": "Text alignment (desktop)",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "hero_height_mobile",
      "label": "Hero height (mobile)",
      "min": 55,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 75
    },
    {
      "type": "range",
      "id": "hero_height_desktop",
      "label": "Hero height (desktop)",
      "min": 60,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 85
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "primary_button_bg",
      "label": "Primary button background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "primary_button_text",
      "label": "Primary button text",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "secondary_button_bg",
      "label": "Secondary button background",
      "default": "transparent"
    },
    {
      "type": "color",
      "id": "secondary_button_text",
      "label": "Secondary button text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "secondary_button_border",
      "label": "Secondary button border",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "High-converting hero"
    }
  ]
}
{% endschema %}

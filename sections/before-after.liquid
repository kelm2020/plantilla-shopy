<section class="section section-before-after page-width" data-section-id="{{ section.id }}">
  <h2 class="section__heading">{{ section.settings.heading }}</h2>
  <div class="before-after">
    <figure>
      {% if section.settings.before_image %}
        {{ section.settings.before_image | image_url: width: 900 | image_tag: class: 'before-after__image', loading: 'lazy' }}
      {% endif %}
      <figcaption>{{ section.settings.before_label }}</figcaption>
    </figure>
    <figure>
      {% if section.settings.after_image %}
        {{ section.settings.after_image | image_url: width: 900 | image_tag: class: 'before-after__image', loading: 'lazy' }}
      {% endif %}
      <figcaption>{{ section.settings.after_label }}</figcaption>
    </figure>
  </div>
</section>

{% schema %}
{
  "name": "Before / After",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Before and after" },
    { "type": "image_picker", "id": "before_image", "label": "Before image" },
    { "type": "text", "id": "before_label", "label": "Before label", "default": "Before" },
    { "type": "image_picker", "id": "after_image", "label": "After image" },
    { "type": "text", "id": "after_label", "label": "After label", "default": "After" }
  ],
  "presets": [
    { "name": "Before / After" }
  ]
}
{% endschema %}
